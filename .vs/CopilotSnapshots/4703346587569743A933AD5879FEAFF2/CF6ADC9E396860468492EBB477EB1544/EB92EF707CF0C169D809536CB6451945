@page "/browse"
@rendermode InteractiveServer
@inject IBikeSearchService BikeSearchService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>SecondBike — Browse Bikes</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
    <MudIcon Icon="@Icons.Material.Filled.DirectionsBike" Class="mr-2" />
    Browse Bikes
</MudText>

<MudGrid Spacing="4">
    @* ??? Filter Sidebar ??? *@
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4 rounded-lg" Elevation="0" Style="border: 1px solid #E8E8E8;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.FilterList" Class="mr-1" /> Filters
            </MudText>

            <MudTextField @bind-Value="_filter.SearchTerm"
                          Label="Search"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="500"
                          OnDebounceIntervalElapsed="SearchAsync"
                          Class="mb-3" />

            <MudSelect T="BikeCategory?" @bind-Value="_filter.Category"
                       Label="Category" Variant="Variant.Outlined"
                       Clearable="true" Class="mb-3">
                @foreach (BikeCategory cat in Enum.GetValues<BikeCategory>())
                {
                    <MudSelectItem Value="@((BikeCategory?)cat)">@cat</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="BikeCondition?" @bind-Value="_filter.Condition"
                       Label="Condition" Variant="Variant.Outlined"
                       Clearable="true" Class="mb-3">
                @foreach (BikeCondition cond in Enum.GetValues<BikeCondition>())
                {
                    <MudSelectItem Value="@((BikeCondition?)cond)">@cond</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="BikeSize?" @bind-Value="_filter.Size"
                       Label="Size" Variant="Variant.Outlined"
                       Clearable="true" Class="mb-3">
                @foreach (BikeSize size in Enum.GetValues<BikeSize>())
                {
                    <MudSelectItem Value="@((BikeSize?)size)">@size</MudSelectItem>
                }
            </MudSelect>

            <MudText Typo="Typo.subtitle2" Class="mb-1">Price Range (VN?)</MudText>
            <MudStack Row Spacing="2" Class="mb-3">
                <MudNumericField T="decimal?" @bind-Value="_filter.MinPrice"
                                 Label="Min" Variant="Variant.Outlined" />
                <MudNumericField T="decimal?" @bind-Value="_filter.MaxPrice"
                                 Label="Max" Variant="Variant.Outlined" />
            </MudStack>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" OnClick="SearchAsync"
                       StartIcon="@Icons.Material.Filled.Search"
                       Class="mb-2">
                Apply Filters
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       FullWidth="true" OnClick="ClearFilters"
                       StartIcon="@Icons.Material.Filled.Clear">
                Clear All
            </MudButton>
        </MudPaper>
    </MudItem>

    @* ??? Results ??? *@
    <MudItem xs="12" md="9">
        @* Sort bar *@
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @if (_result is not null)
                {
                    <b>@_result.TotalCount</b> @:bikes found
                }
            </MudText>
            <MudSelect T="string" Value="_filter.SortBy"
                       Label="Sort by" Variant="Variant.Outlined"
                       Style="max-width:200px;"
                       ValueChanged="OnSortChanged">
                <MudSelectItem Value="@("newest")">Newest First</MudSelectItem>
                <MudSelectItem Value="@("oldest")">Oldest First</MudSelectItem>
                <MudSelectItem Value="@("price_asc")">Price: Low ? High</MudSelectItem>
                <MudSelectItem Value="@("price_desc")">Price: High ? Low</MudSelectItem>
                <MudSelectItem Value="@("popular")">Most Popular</MudSelectItem>
            </MudSelect>
        </MudStack>

        @if (_loading)
        {
            <MudGrid Spacing="3">
                @for (int i = 0; i < 6; i++)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg" />
                        <MudSkeleton Width="80%" Class="mt-2" />
                        <MudSkeleton Width="50%" />
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <MudPaper Class="pa-8 d-flex flex-column align-center rounded-lg" Elevation="0"
                      Style="border: 2px dashed #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Class="mt-3">No bikes found</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Try adjusting your filters or search term.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var bike in _result.Items)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudCard Elevation="0" Class="rounded-lg bike-card"
                                 Style="border: 1px solid #E8E8E8; cursor: pointer; transition: all 0.2s;"
                                 @onclick="() => ViewDetail(bike.Id)">
                            <MudCardMedia Image="@(bike.Images.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/400x250?text=No+Image")"
                                          Height="200" Class="rounded-t-lg" />
                            <MudCardContent Class="pa-4">
                                <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                        @bike.Title
                                    </MudText>
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                                        @bike.Condition
                                    </MudChip>
                                </MudStack>

                                <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight: 700;" Class="mt-1">
                                    @bike.Price.ToString("N0") ?
                                </MudText>

                                <MudStack Row Spacing="2" Class="mt-2">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@bike.Brand</MudChip>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@bike.Category</MudChip>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@bike.Size</MudChip>
                                </MudStack>

                                <MudDivider Class="my-2" />

                                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @bike.SellerName[0]
                                    </MudAvatar>
                                    <MudText Typo="Typo.body2">@bike.SellerName</MudText>
                                    @if (bike.IsVerifiedSeller)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Verified"
                                                 Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudSpacer />
                                    <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Visibility"
                                                 Size="Size.Small" Color="Color.Default" />
                                        <MudText Typo="Typo.caption">@bike.ViewCount</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>

            @* Pagination *@
            @if (_result.TotalPages > 1)
            {
                <MudStack AlignItems="AlignItems.Center" Class="mt-6">
                    <MudPagination Count="@_result.TotalPages"
                                   Selected="@_filter.Page"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled" />
                </MudStack>
            }
        }
    </MudItem>
</MudGrid>

@code {
    private BikeFilterDto _filter = new();
    private Application.Common.PagedResult<BikePostDto>? _result;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _loading = true;
        StateHasChanged();

        var response = await BikeSearchService.SearchAsync(_filter);
        if (response.IsSuccess)
            _result = response.Data;

        _loading = false;
    }

    private async Task OnSortChanged(string sort)
    {
        _filter.SortBy = sort;
        _filter.Page = 1;
        await SearchAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _filter.Page = page;
        await SearchAsync();
    }

    private async Task ClearFilters()
    {
        _filter = new BikeFilterDto();
        await SearchAsync();
    }

    private void ViewDetail(Guid id) => Nav.NavigateTo($"/bike/{id}");
}
