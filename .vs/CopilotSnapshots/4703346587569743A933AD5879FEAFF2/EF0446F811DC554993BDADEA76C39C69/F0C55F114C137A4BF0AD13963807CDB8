@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* ─── Top App Bar ─── *@
    <MudAppBar Elevation="1" Dense="false" Color="Color.Surface">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Dark"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />

        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.DirectionsBike"
                     Color="Color.Primary"
                     Size="Size.Large" />
            <MudText Typo="Typo.h5"
                     Style="font-weight: 700; color: #0056D2;">
                Second<span style="color: #FF6B00;">Bike</span>
            </MudText>
        </MudStack>

        <MudSpacer />

        <MudIconButton Icon="@Icons.Material.Outlined.Search"
                       Color="Color.Dark" />
        <MudIconButton Icon="@Icons.Material.Outlined.FavoriteBorder"
                       Color="Color.Dark" />
        <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                       Color="Color.Dark" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Login"
                   Class="ml-2">
            Sign In
        </MudButton>
    </MudAppBar>

    @* ─── Side Navigation Drawer ─── *@
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true">
        <MudNavMenu>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">
                Home
            </MudNavLink>
            <MudNavLink Href="/browse"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.DirectionsBike">
                Browse Bikes
            </MudNavLink>
            <MudNavLink Href="/sell"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Sell">
                Sell Your Bike
            </MudNavLink>
            <MudNavLink Href="/my-posts"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Inventory">
                My Posts
            </MudNavLink>

            <MudDivider Class="my-2" />

            <MudNavLink Href="/orders"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Receipt">
                My Orders
            </MudNavLink>
            <MudNavLink Href="/wishlist"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Favorite">
                Wishlist
            </MudNavLink>
            <MudNavLink Href="/chat"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Chat">
                Messages
            </MudNavLink>

            <MudDivider Class="my-2" />

            <MudNavLink Href="/inspect"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.FactCheck">
                Inspections
            </MudNavLink>
            <MudNavLink Href="/admin"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.AdminPanelSettings">
                Admin
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    @* ─── Main Content Area ─── *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    /// <summary>
    /// Custom MudBlazor theme aligned with SecondBike brand identity.
    /// Primary = Deep Blue (#0056D2) for trust.
    /// Secondary = Vibrant Orange (#FF6B00) for energy and sport.
    /// </summary>
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0056D2",
            Secondary = "#FF6B00",
            Background = "#F4F5F7",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1A1A2E",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#1A1A2E",
            TextPrimary = "#1A1A2E",
            TextSecondary = "#5A6072",
            ActionDefault = "#5A6072",
            Success = "#27AE60",
            Warning = "#F39C12",
            Error = "#E74C3C",
            Info = "#0056D2"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#3B82F6",
            Secondary = "#FF8C3A",
            Background = "#0F172A",
            Surface = "#1E293B",
            AppbarBackground = "#1E293B",
            AppbarText = "#F1F5F9",
            DrawerBackground = "#1E293B",
            DrawerText = "#F1F5F9",
            TextPrimary = "#F1F5F9",
            TextSecondary = "#94A3B8",
            Success = "#22C55E",
            Warning = "#FBBF24",
            Error = "#EF4444",
            Info = "#3B82F6"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Inter", "Roboto", "Helvetica", "Arial", "sans-serif" }
            },
            H1 = new H1Typography
            {
                FontWeight = 700,
                FontSize = "2.5rem"
            },
            H2 = new H2Typography
            {
                FontWeight = 700,
                FontSize = "2rem"
            },
            H3 = new H3Typography
            {
                FontWeight = 600,
                FontSize = "1.75rem"
            },
            H5 = new H5Typography
            {
                FontWeight = 600,
                FontSize = "1.25rem"
            },
            Button = new ButtonTypography
            {
                FontWeight = 600,
                TextTransform = "none"
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
            DrawerWidthLeft = "260px",
            DrawerMiniWidthLeft = "56px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
