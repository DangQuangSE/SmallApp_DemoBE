@page "/wishlist"
@rendermode InteractiveServer
@inject IWishlistService WishlistService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>SecondBike — My Wishlist</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
    <MudIcon Icon="@Icons.Material.Filled.Favorite" Class="mr-2" Color="Color.Error" /> My Wishlist
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_bikes.Count == 0)
{
    <MudPaper Class="pa-8 d-flex flex-column align-center rounded-lg" Elevation="0"
              Style="border: 2px dashed #E8E8E8;">
        <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-3">Your wishlist is empty</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Browse bikes and save the ones you love!
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => Nav.NavigateTo("/browse"))">
            Browse Bikes
        </MudButton>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var bike in _bikes)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="0" Class="rounded-lg" Style="border: 1px solid #E8E8E8;">
                    <MudCardMedia Image="@(bike.Images.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/400x200")"
                                  Height="180" />
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@bike.Title</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight: 700;">
                            @bike.Price.ToString("N0") ?
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @bike.Brand · @bike.Category · @bike.City
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => Nav.NavigateTo($"/bike/{bike.Id}"))">
                            View
                        </MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.HeartBroken"
                                       Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => RemoveFromWishlist(bike.Id))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<BikePostDto> _bikes = new();
    private bool _loading = true;
    private Guid _currentUserId = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var result = await WishlistService.GetByUserAsync(_currentUserId);
        if (result.IsSuccess && result.Data is not null)
            _bikes = result.Data;
        _loading = false;
    }

    private async Task RemoveFromWishlist(Guid bikePostId)
    {
        var result = await WishlistService.RemoveAsync(_currentUserId, bikePostId);
        if (result.IsSuccess)
        {
            _bikes.RemoveAll(b => b.Id == bikePostId);
            Snackbar.Add("Removed from wishlist", Severity.Success);
        }
    }
}
