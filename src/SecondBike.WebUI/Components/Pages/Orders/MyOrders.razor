@page "/orders"
@rendermode InteractiveServer
@inject IOrderService OrderService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>SecondBike — My Orders</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" /> My Orders
</MudText>

<MudTabs Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" Class="mb-4">
    <MudTabPanel Text="As Buyer" Icon="@Icons.Material.Filled.ShoppingBag">
        @if (_buyerOrders.Count == 0)
        {
            <MudPaper Class="pa-6 d-flex flex-column align-center rounded-lg mt-4" Elevation="0"
                      Style="border: 2px dashed #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Class="mt-3">No orders yet</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                           OnClick="@(() => Nav.NavigateTo("/browse"))">
                    Browse Bikes
                </MudButton>
            </MudPaper>
        }
        else
        {
            @foreach (var order in _buyerOrders)
            {
                <OrderCard Order="order" IsBuyer="true"
                           OnConfirmDelivery="ConfirmDelivery"
                           OnCancelOrder="CancelOrder"
                           OnOpenDispute="OpenDispute" />
            }
        }
    </MudTabPanel>
    <MudTabPanel Text="As Seller" Icon="@Icons.Material.Filled.Storefront">
        @if (_sellerOrders.Count == 0)
        {
            <MudPaper Class="pa-6 d-flex flex-column align-center rounded-lg mt-4" Elevation="0"
                      Style="border: 2px dashed #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Class="mt-3">No sales yet</MudText>
            </MudPaper>
        }
        else
        {
            @foreach (var order in _sellerOrders)
            {
                <OrderCard Order="order" IsBuyer="false" />
            }
        }
    </MudTabPanel>
</MudTabs>

@code {
    private List<OrderDto> _buyerOrders = new();
    private List<OrderDto> _sellerOrders = new();

    // Placeholder user ID
    private Guid _currentUserId = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        var buyerResult = await OrderService.GetByBuyerAsync(_currentUserId);
        if (buyerResult.IsSuccess && buyerResult.Data is not null)
            _buyerOrders = buyerResult.Data;

        var sellerResult = await OrderService.GetBySellerAsync(_currentUserId);
        if (sellerResult.IsSuccess && sellerResult.Data is not null)
            _sellerOrders = sellerResult.Data;
    }

    private async Task ConfirmDelivery(Guid orderId)
    {
        var result = await OrderService.ConfirmDeliveryAsync(_currentUserId, orderId);
        if (result.IsSuccess) Snackbar.Add("Delivery confirmed!", Severity.Success);
    }

    private async Task CancelOrder(Guid orderId)
    {
        var result = await OrderService.CancelOrderAsync(_currentUserId, orderId, "Buyer cancelled");
        if (result.IsSuccess) Snackbar.Add("Order cancelled", Severity.Warning);
    }

    private async Task OpenDispute(Guid orderId)
    {
        var result = await OrderService.OpenDisputeAsync(_currentUserId, orderId, "Issue with order");
        if (result.IsSuccess) Snackbar.Add("Dispute opened", Severity.Info);
    }
}
