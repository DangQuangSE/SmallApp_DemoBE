@page "/order/create/{BikePostId:guid}"
@rendermode InteractiveServer
@inject IOrderService OrderService
@inject IBikeSearchService BikeSearchService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>SecondBike — Place Order</PageTitle>

<MudBreadcrumbs Items="@(new List<BreadcrumbItem>
{
    new("Home", "/"), new("Browse", "/browse"),
    new("Order", null, disabled: true)
})" Class="mb-4 px-0" />

@if (_bike is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="4">
        @* ??? Order Summary ??? *@
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-5 rounded-lg" Elevation="0" Style="border: 1px solid #E8E8E8;">
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
                    Place Order
                </MudText>

                @* Bike Summary *@
                <MudStack Row Spacing="3" Class="mb-4">
                    <MudImage Src="@(_bike.Images.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/120")"
                              Width="120" Height="90" ObjectFit="ObjectFit.Cover" Class="rounded" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_bike.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_bike.Brand @_bike.Model · @_bike.Year</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight: 700;">
                            @_bike.Price.ToString("N0") ?
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudDivider Class="my-3" />

                @* Shipping Address *@
                <MudTextField @bind-Value="_shippingAddress" Label="Shipping Address"
                              Variant="Variant.Outlined" Lines="3" Required="true"
                              Placeholder="Enter your full shipping address..."
                              HelperText="Include street, district, city, and postal code"
                              Class="mb-4" />

                @* Deposit Selection *@
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-2">
                    Deposit Percentage
                </MudText>
                <MudSlider @bind-Value="_depositPct" Min="10" Max="30" Step="5"
                           Color="Color.Primary" Class="mb-1">
                    Deposit: @_depositPct%
                </MudSlider>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    You pay the deposit now, and the remaining amount upon delivery.
                </MudText>
            </MudPaper>
        </MudItem>

        @* ??? Price Breakdown ??? *@
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-5 rounded-lg" Elevation="0"
                      Style="border: 2px solid #0056D2; position: sticky; top: 80px;">
                <MudText Typo="Typo.h6" Style="font-weight: 700;" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-1" />
                    Order Summary
                </MudText>

                <MudStack Spacing="2">
                    <MudStack Row Justify="Justify.SpaceBetween">
                        <MudText>Bike Price</MudText>
                        <MudText Style="font-weight: 600;">@_bike.Price.ToString("N0") ?</MudText>
                    </MudStack>
                    <MudStack Row Justify="Justify.SpaceBetween">
                        <MudText Color="Color.Success">Deposit (@_depositPct%)</MudText>
                        <MudText Style="font-weight: 600;" Color="Color.Success">
                            @DepositAmount.ToString("N0") ?
                        </MudText>
                    </MudStack>
                    <MudStack Row Justify="Justify.SpaceBetween">
                        <MudText Color="Color.Secondary">Remaining</MudText>
                        <MudText Color="Color.Secondary">
                            @RemainingAmount.ToString("N0") ?
                        </MudText>
                    </MudStack>

                    <MudDivider />

                    <MudStack Row Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">Pay Now</MudText>
                        <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 800;">
                            @DepositAmount.ToString("N0") ?
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" Class="mt-4"
                           Disabled="@(string.IsNullOrWhiteSpace(_shippingAddress) || _submitting)"
                           OnClick="SubmitOrder"
                           StartIcon="@Icons.Material.Filled.Lock">
                    @if (_submitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @:Processing...
                    }
                    else
                    {
                        @:Place Order & Pay Deposit
                    }
                </MudButton>

                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                    Your deposit is protected. Full refund if the seller doesn't confirm within 48 hours.
                </MudAlert>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid BikePostId { get; set; }

    private BikePostDto? _bike;
    private string _shippingAddress = "";
    private decimal _depositPct = 15;
    private bool _submitting;

    private decimal DepositAmount => _bike is null ? 0 : Math.Round(_bike.Price * _depositPct / 100, 0);
    private decimal RemainingAmount => (_bike?.Price ?? 0) - DepositAmount;

    // Placeholder buyer ID
    private Guid _currentBuyerId = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        var result = await BikeSearchService.GetDetailAsync(BikePostId);
        if (result.IsSuccess) _bike = result.Data;
    }

    private async Task SubmitOrder()
    {
        if (_bike is null) return;
        _submitting = true;

        var dto = new CreateOrderDto
        {
            BikePostId = _bike.Id,
            ShippingAddress = _shippingAddress,
            DepositPercentage = _depositPct
        };

        var result = await OrderService.PlaceOrderAsync(_currentBuyerId, dto);
        if (result.IsSuccess && result.Data is not null)
        {
            Snackbar.Add($"Order {result.Data.OrderNumber} placed!", Severity.Success);
            Nav.NavigateTo($"/orders");
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? "Order failed", Severity.Error);
        }

        _submitting = false;
    }
}
