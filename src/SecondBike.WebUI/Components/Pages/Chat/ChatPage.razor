@page "/chat"
@page "/chat/{OtherUserId:guid}"
@rendermode InteractiveServer
@inject IMessageService MessageService
@inject ISnackbar Snackbar

<PageTitle>SecondBike — Messages</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
    <MudIcon Icon="@Icons.Material.Filled.Chat" Class="mr-2" /> Messages
</MudText>

<MudGrid Spacing="0">
    @* ??? Conversations List ??? *@
    <MudItem xs="12" md="4">
        <MudPaper Class="rounded-l-lg" Elevation="0"
                  Style="border: 1px solid #E8E8E8; height: 600px; overflow-y: auto;">
            <MudList T="ConversationDto" Dense Class="py-0">
                @if (_conversations.Count == 0)
                {
                    <MudListItem T="ConversationDto">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                            No conversations yet
                        </MudText>
                    </MudListItem>
                }
                else
                {
                    @foreach (var conv in _conversations)
                    {
                        <MudListItem T="ConversationDto" OnClick="@(() => SelectConversation(conv.OtherUserId))"
                                     Class="@(conv.OtherUserId == _selectedUserId ? "mud-primary-text" : "")">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudBadge Content="@conv.UnreadCount" Overlap="true"
                                          Visible="@(conv.UnreadCount > 0)" Color="Color.Error">
                                    <MudAvatar Size="Size.Medium" Color="Color.Primary">
                                        @conv.OtherUserName[0]
                                    </MudAvatar>
                                </MudBadge>
                                <MudStack Spacing="0" Style="flex:1; min-width:0;">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                        @conv.OtherUserName
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @conv.LastMessage
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @conv.LastMessageAt.ToString("HH:mm")
                                </MudText>
                            </MudStack>
                        </MudListItem>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>

    @* ??? Chat Window ??? *@
    <MudItem xs="12" md="8">
        <MudPaper Class="rounded-r-lg d-flex flex-column" Elevation="0"
                  Style="border: 1px solid #E8E8E8; border-left: none; height: 600px;">
            @if (_selectedUserId == Guid.Empty)
            {
                <div class="d-flex flex-column align-center justify-center flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline"
                             Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-3">
                        Select a conversation
                    </MudText>
                </div>
            }
            else
            {
                @* Messages area *@
                <div style="flex: 1; overflow-y: auto; padding: 16px;">
                    @foreach (var msg in _messages)
                    {
                        var isMine = msg.SenderId == _currentUserId;
                        <div class="d-flex @(isMine ? "justify-end" : "justify-start") mb-2">
                            @if (!isMine)
                            {
                                <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-2 mt-1">
                                    @msg.SenderName[0]
                                </MudAvatar>
                            }
                            <MudPaper Class="pa-3 rounded-lg" Elevation="0"
                                      Style="@($"max-width:70%; background: {(isMine ? "#0056D2" : "#F0F0F0")}; color: {(isMine ? "white" : "#1A1A2E")};")">
                                <MudText Typo="Typo.body2">@msg.Content</MudText>
                                <MudText Typo="Typo.caption"
                                         Style="@($"opacity:0.7; color: {(isMine ? "rgba(255,255,255,0.7)" : "#999")};")">
                                    @msg.CreatedAt.ToString("HH:mm")
                                </MudText>
                            </MudPaper>
                        </div>
                    }
                </div>

                @* Input area *@
                <MudPaper Class="pa-3" Elevation="0" Style="border-top: 1px solid #E8E8E8;">
                    <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                        <MudTextField @bind-Value="_newMessage" Variant="Variant.Outlined"
                                      Placeholder="Type a message..." Class="flex-grow-1"
                                      Immediate="true"
                                      OnKeyDown="OnKeyDown" />
                        <MudIconButton Icon="@Icons.Material.Filled.Send"
                                       Color="Color.Primary" Variant="Variant.Filled"
                                       OnClick="SendMessage"
                                       Disabled="@string.IsNullOrWhiteSpace(_newMessage)" />
                    </MudStack>
                </MudPaper>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public Guid? OtherUserId { get; set; }
    [SupplyParameterFromQuery(Name = "bike")] public Guid? BikePostId { get; set; }

    private List<ConversationDto> _conversations = new();
    private List<MessageDto> _messages = new();
    private Guid _selectedUserId;
    private string _newMessage = "";

    // Placeholder
    private Guid _currentUserId = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        var convResult = await MessageService.GetConversationsAsync(_currentUserId);
        if (convResult.IsSuccess && convResult.Data is not null)
            _conversations = convResult.Data;

        if (OtherUserId.HasValue && OtherUserId.Value != Guid.Empty)
            await SelectConversation(OtherUserId.Value);
    }

    private async Task SelectConversation(Guid otherUserId)
    {
        _selectedUserId = otherUserId;
        var result = await MessageService.GetConversationAsync(_currentUserId, otherUserId);
        if (result.IsSuccess && result.Data is not null)
            _messages = result.Data;

        await MessageService.MarkAsReadAsync(_currentUserId, otherUserId);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newMessage) || _selectedUserId == Guid.Empty) return;

        var result = await MessageService.SendAsync(_currentUserId, new SendMessageDto
        {
            ReceiverId = _selectedUserId,
            BikePostId = BikePostId,
            Content = _newMessage
        });

        if (result.IsSuccess && result.Data is not null)
        {
            _messages.Add(result.Data);
            _newMessage = "";
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }
}
