@page "/admin"
@rendermode InteractiveServer
@inject IAdminService AdminService
@inject ISnackbar Snackbar

<PageTitle>SecondBike — Admin Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" /> Admin Dashboard
</MudText>

@* ??? Stats Cards ??? *@
@if (_stats is not null)
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 1px solid #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">@_stats.TotalUsers</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Users</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 1px solid #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.DirectionsBike" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">@_stats.TotalActivePosts</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Active Posts</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 2px solid #F39C12;">
                <MudIcon Icon="@Icons.Material.Filled.Pending" Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">@_stats.PendingModerations</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 2px solid #E74C3C;">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">@_stats.OpenDisputes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Disputes</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 1px solid #E8E8E8;">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">@_stats.TotalOrders</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Orders</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-lg d-flex flex-column align-center" Elevation="0"
                      Style="border: 1px solid #27AE60;">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-1">
                    @(_stats.TotalRevenue / 1_000_000)M
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Revenue (?)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@* ??? Tabs ??? *@
<MudTabs Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary">
    @* ??? Post Moderation ??? *@
    <MudTabPanel Text="Moderate Posts" Icon="@Icons.Material.Filled.RateReview"
                 BadgeData="@_pendingPosts.Count" BadgeColor="Color.Warning">
        @if (_pendingPosts.Count == 0)
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                No posts pending moderation. All caught up! ?
            </MudAlert>
        }
        else
        {
            <MudTable Items="@_pendingPosts" Hover Elevation="0" Class="mt-2"
                      Style="border: 1px solid #E8E8E8; border-radius: 8px;">
                <HeaderContent>
                    <MudTh>Image</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Seller</MudTh>
                    <MudTh>Price</MudTh>
                    <MudTh>Category</MudTh>
                    <MudTh>Submitted</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudImage Src="@(context.PrimaryImageUrl ?? "https://via.placeholder.com/50")"
                                  Width="50" Height="40" ObjectFit="ObjectFit.Cover" Class="rounded" />
                    </MudTd>
                    <MudTd><MudText Style="font-weight:500;">@context.Title</MudText></MudTd>
                    <MudTd>@context.SellerName</MudTd>
                    <MudTd Style="font-weight:600; color:#FF6B00;">@context.Price.ToString("N0") ?</MudTd>
                    <MudTd>@context.Category</MudTd>
                    <MudTd>@context.CreatedAt.ToString("MMM dd")</MudTd>
                    <MudTd>
                        <MudStack Row Spacing="1">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="@(() => ApprovePost(context.Id))">
                                Approve
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       OnClick="@(() => OpenRejectDialog(context.Id))">
                                Reject
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    @* ??? Disputes ??? *@
    <MudTabPanel Text="Disputes" Icon="@Icons.Material.Filled.Gavel"
                 BadgeData="@_disputes.Count" BadgeColor="Color.Error">
        @if (_disputes.Count == 0)
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                No open disputes. ??
            </MudAlert>
        }
        else
        {
            <MudTable Items="@_disputes" Hover Elevation="0" Class="mt-2"
                      Style="border: 1px solid #E8E8E8; border-radius: 8px;">
                <HeaderContent>
                    <MudTh>Order #</MudTh>
                    <MudTh>Bike</MudTh>
                    <MudTh>Buyer</MudTh>
                    <MudTh>Seller</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-weight:500;">@context.OrderNumber</MudTd>
                    <MudTd>@context.BikeTitle</MudTd>
                    <MudTd>@context.BuyerName</MudTd>
                    <MudTd>@context.SellerName</MudTd>
                    <MudTd Style="font-weight:600;">@context.TotalAmount.ToString("N0") ?</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenResolveDialog(context.Id))">
                            Resolve
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    @* ??? User Management ??? *@
    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.People">
        <MudStack Row Spacing="2" Class="my-3">
            <MudButton Variant="@(_roleFilter is null ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => FilterByRole(null))">All</MudButton>
            @foreach (UserRole r in Enum.GetValues<UserRole>())
            {
                <MudButton Variant="@(_roleFilter == r ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="@(() => FilterByRole(r))">@r</MudButton>
            }
        </MudStack>

        <MudTable Items="@_users" Hover Elevation="0"
                  Style="border: 1px solid #E8E8E8; border-radius: 8px;">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Role</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Posts</MudTh>
                <MudTh>Orders</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-weight:500;">@context.FullName</MudTd>
                <MudTd>@context.Email</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small">@context.Role</MudChip></MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Status == UserStatus.Active ? Color.Success : Color.Error)">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd>@context.TotalPosts</MudTd>
                <MudTd>@context.TotalOrders</MudTd>
                <MudTd>
                    @if (context.Status == UserStatus.Active)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                   OnClick="@(() => SuspendUser(context.Id))">
                            Suspend
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                   OnClick="@(() => ActivateUser(context.Id))">
                            Activate
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>
</MudTabs>

@* ??? Reject Dialog ??? *@
<MudDialog @bind-Visible="_showRejectDialog">
    <DialogContent>
        <MudText Class="mb-3">Provide a reason for rejection:</MudText>
        <MudTextField @bind-Value="_rejectReason" Label="Rejection Reason"
                      Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showRejectDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="RejectPost">Reject</MudButton>
    </DialogActions>
</MudDialog>

@* ??? Resolve Dispute Dialog ??? *@
<MudDialog @bind-Visible="_showResolveDialog">
    <DialogContent>
        <MudTextField @bind-Value="_resolution" Label="Resolution"
                      Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudCheckBox @bind-Value="_refundBuyer" Label="Refund Buyer" Color="Color.Primary" />
        <MudCheckBox @bind-Value="_banSeller" Label="Ban Seller" Color="Color.Error" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showResolveDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResolveDispute">Resolve</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private DashboardStatsDto? _stats;
    private List<PendingPostDto> _pendingPosts = new();
    private List<OrderDto> _disputes = new();
    private List<AdminUserDto> _users = new();
    private UserRole? _roleFilter;

    // Reject dialog
    private bool _showRejectDialog;
    private Guid _rejectPostId;
    private string _rejectReason = "";

    // Resolve dialog
    private bool _showResolveDialog;
    private Guid _resolveOrderId;
    private string _resolution = "";
    private bool _refundBuyer;
    private bool _banSeller;

    private Guid _adminId = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        var statsResult = await AdminService.GetDashboardStatsAsync();
        if (statsResult.IsSuccess) _stats = statsResult.Data;

        var pendingResult = await AdminService.GetPendingPostsAsync();
        if (pendingResult.IsSuccess && pendingResult.Data is not null)
            _pendingPosts = pendingResult.Data;

        var disputeResult = await AdminService.GetDisputedOrdersAsync();
        if (disputeResult.IsSuccess && disputeResult.Data is not null)
            _disputes = disputeResult.Data;

        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        var result = await AdminService.GetUsersAsync(_roleFilter);
        if (result.IsSuccess && result.Data is not null)
            _users = result.Data;
    }

    private async Task FilterByRole(UserRole? role)
    {
        _roleFilter = role;
        await LoadUsers();
    }

    private async Task ApprovePost(Guid postId)
    {
        await AdminService.ModeratePostAsync(_adminId, new ModeratePostDto { BikePostId = postId, Approve = true });
        Snackbar.Add("Post approved ?", Severity.Success);
        await LoadAll();
    }

    private void OpenRejectDialog(Guid postId)
    {
        _rejectPostId = postId;
        _rejectReason = "";
        _showRejectDialog = true;
    }

    private async Task RejectPost()
    {
        await AdminService.ModeratePostAsync(_adminId, new ModeratePostDto
        {
            BikePostId = _rejectPostId,
            Approve = false,
            RejectionReason = _rejectReason
        });
        _showRejectDialog = false;
        Snackbar.Add("Post rejected", Severity.Warning);
        await LoadAll();
    }

    private void OpenResolveDialog(Guid orderId)
    {
        _resolveOrderId = orderId;
        _resolution = "";
        _refundBuyer = false;
        _banSeller = false;
        _showResolveDialog = true;
    }

    private async Task ResolveDispute()
    {
        await AdminService.ResolveDisputeAsync(_adminId, new ResolveDisputeDto
        {
            OrderId = _resolveOrderId,
            Resolution = _resolution,
            RefundBuyer = _refundBuyer,
            BanSeller = _banSeller
        });
        _showResolveDialog = false;
        Snackbar.Add("Dispute resolved", Severity.Success);
        await LoadAll();
    }

    private async Task SuspendUser(Guid userId)
    {
        await AdminService.UpdateUserStatusAsync(_adminId, userId, UserStatus.Suspended);
        Snackbar.Add("User suspended", Severity.Warning);
        await LoadUsers();
    }

    private async Task ActivateUser(Guid userId)
    {
        await AdminService.UpdateUserStatusAsync(_adminId, userId, UserStatus.Active);
        Snackbar.Add("User activated", Severity.Success);
        await LoadUsers();
    }
}
