@page "/ratings/{SellerId:guid}"
@rendermode InteractiveServer
@inject IRatingService RatingService
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>SecondBike — Seller Ratings</PageTitle>

@if (_seller is not null)
{
    @* ??? Seller Header ??? *@
    <MudPaper Class="pa-5 rounded-lg mb-4" Elevation="0" Style="border: 1px solid #E8E8E8;">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="4">
            <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width:64px; height:64px; font-size:1.5rem;">
                @_seller.FullName[0]
            </MudAvatar>
            <MudStack Spacing="0">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">@_seller.FullName</MudText>
                    @if (_seller.IsVerifiedSeller)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Primary" />
                    }
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                    <MudRating ReadOnly SelectedValue="@((int)_seller.SellerRating)" Size="Size.Medium" />
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">
                        @_seller.SellerRating.ToString("F1")
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        (@_seller.TotalRatingsCount reviews)
                    </MudText>
                </MudStack>
            </MudStack>
        </MudStack>
    </MudPaper>

    @* ??? Ratings List ??? *@
    @if (_ratings.Count == 0)
    {
        <MudPaper Class="pa-6 d-flex flex-column align-center rounded-lg" Elevation="0"
                  Style="border: 2px dashed #E8E8E8;">
            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Class="mt-3">No reviews yet</MudText>
        </MudPaper>
    }
    else
    {
        @foreach (var rating in _ratings)
        {
            <MudPaper Class="pa-4 rounded-lg mb-3" Elevation="0" Style="border: 1px solid #E8E8E8;">
                <MudStack Row AlignItems="AlignItems.Start" Spacing="3">
                    <MudAvatar Size="Size.Medium" Color="Color.Surface"
                               Style="border: 1px solid #E8E8E8;">
                        @rating.FromUserName[0]
                    </MudAvatar>
                    <MudStack Spacing="1" Style="flex:1;">
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                @rating.FromUserName
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @rating.CreatedAt.ToString("MMM dd, yyyy")
                            </MudText>
                        </MudStack>
                        <MudRating ReadOnly SelectedValue="@rating.Stars" Size="Size.Small" />

                        @if (!string.IsNullOrEmpty(rating.Comment))
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">@rating.Comment</MudText>
                        }

                        @* Detailed ratings *@
                        @if (rating.CommunicationRating.HasValue || rating.AccuracyRating.HasValue)
                        {
                            <MudStack Row Spacing="3" Class="mt-2">
                                @if (rating.CommunicationRating.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Chat">
                                        Communication: @rating.CommunicationRating/5
                                    </MudChip>
                                }
                                @if (rating.AccuracyRating.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                        Accuracy: @rating.AccuracyRating/5
                                    </MudChip>
                                }
                                @if (rating.PackagingRating.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Inventory2">
                                        Packaging: @rating.PackagingRating/5
                                    </MudChip>
                                }
                                @if (rating.SpeedRating.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Speed">
                                        Speed: @rating.SpeedRating/5
                                    </MudChip>
                                }
                            </MudStack>
                        }

                        @* Seller Response *@
                        @if (!string.IsNullOrEmpty(rating.SellerResponse))
                        {
                            <MudPaper Class="pa-3 mt-2 rounded" Elevation="0"
                                      Style="background: #F4F5F7; border-left: 3px solid #0056D2;">
                                <MudText Typo="Typo.caption" Style="font-weight: 600;" Color="Color.Primary">
                                    Seller Response:
                                </MudText>
                                <MudText Typo="Typo.body2">@rating.SellerResponse</MudText>
                            </MudPaper>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    }
}
else
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

@code {
    [Parameter] public Guid SellerId { get; set; }

    private UserProfileDto? _seller;
    private List<RatingDto> _ratings = new();

    protected override async Task OnInitializedAsync()
    {
        var profileResult = await AuthService.GetProfileAsync(SellerId);
        if (profileResult.IsSuccess) _seller = profileResult.Data;

        var ratingsResult = await RatingService.GetBySellerAsync(SellerId);
        if (ratingsResult.IsSuccess && ratingsResult.Data is not null)
            _ratings = ratingsResult.Data;
    }
}
